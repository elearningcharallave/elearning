rules_version = '2';
// ============================================================================
// FUNCECAIND — Reglas de seguridad de Firestore
// Pega TODO esto en: Firebase Console → Firestore Database → pestaña "Reglas".
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // 👇 PON AQUÍ EL MISMO CORREO QUE EN assets/firebase-config.js (ADMIN_EMAIL).
    //    Solo ESE correo puede auto-asignarse el rol de administrador.
    function adminEmail() { return 'admin@funcecaind.edu.ve'; }

    function signedIn() { return request.auth != null; }
    function tengoDoc() { return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)); }
    function miRol() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol; }
    function isAdmin() { return signedIn() && tengoDoc() && miRol() == 'admin'; }
    function esCorreoAdmin() { return signedIn() && request.auth.token.email == adminEmail(); }

    // ---- Usuarios ----
    match /usuarios/{uid} {
      // Leer el propio perfil; el admin lee a todos.
      allow get:  if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();

      // Crear: tu propio doc como ALUMNO (o ADMIN solo si tu correo es el admin),
      //        o un ADMIN creando la cuenta de un profesor.
      allow create: if (request.auth.uid == uid
                        && (request.resource.data.rol == 'alumno'
                            || (request.resource.data.rol == 'admin' && esCorreoAdmin())))
                     || isAdmin();

      // Editar / borrar usuarios: solo el admin.
      allow update, delete: if isAdmin();
    }

    // ---- Clases ----
    match /clases/{id} {
      // Cualquier usuario autenticado ve las clases (para unirse).
      allow read: if signedIn();

      // Crear: un PROFESOR para sí mismo, o un ADMIN.
      allow create: if (signedIn() && tengoDoc() && miRol() == 'profesor'
                        && request.resource.data.profesorId == request.auth.uid)
                     || isAdmin();

      // Editar / borrar: el profesor dueño o un admin.
      allow update, delete: if (signedIn() && resource.data.profesorId == request.auth.uid)
                             || isAdmin();
    }
  }
}
